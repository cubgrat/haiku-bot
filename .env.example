# --- Telegram ---
# Токен бота от @BotFather (нужен всегда)
BOT_TOKEN=

# --- Нейросети ---
# Provider: Mock — тестовый этап без внешнего API (ключ не нужен);
#           OpenAiCompatible — реальный LLM (нужен LLM_API_KEY).
LLM_PROVIDER=Mock

# Нужно только при LLM_PROVIDER=OpenAiCompatible.
# По умолчанию — OpenRouter. Ключ: https://openrouter.ai/keys
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_GENERATOR_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_JUDGE_MODEL=google/gemini-2.0-flash-exp:free

# --- Пайплайн ---
# Сколько раз пробуем сгенерировать, пока критик не одобрит
MAX_GENERATION_ATTEMPTS=3
# Минимальная оценка критика (0-10) для одобрения
APPROVAL_THRESHOLD=7

# --- Postgres ---
POSTGRES_USER=haiku
POSTGRES_PASSWORD=haiku
POSTGRES_DB=haiku
